# 📈 PnL Tracker Settings (admin only)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
PNL_STOP_LOSS_PCT=30                            # auto-close signal if drops this %
PNL_TAKE_PROFIT_PCT=50                          # auto-close signal if gains this %
PNL_AUTO_CLOSE_HOURS=8                          # auto-close all open signals after X hours
PNL_UPDATE_INTERVAL=60                          # minutes between auto PnL checks

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🐋 Whale Tracker Settings
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
WHALE_MIN_WIN_RATE=65                           # minimum win rate % to track a wallet
WHALE_MIN_SCORE=70                              # minimum Gemini score to add wallet
WHALE_MAX_TRACKED=20                            # max wallets to track at once
WHALE_CHECK_INTERVAL=30                         # minutes between whale wallet checks

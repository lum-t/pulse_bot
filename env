# ⚡ PULSE BOT — Environment Variables
# Copy this to .env and fill in your values
# ⚠️  NEVER share this file or upload it to GitHub
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Telegram Bot ─────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=your_channel_id_here        # e.g. -1001234567890

# ─── Admin User IDs ───────────────────────────────────────────
# Only these users can send commands to the bot
# Get yours by messaging @userinfobot on Telegram
ADMIN_1_ID=your_user_id_here
ADMIN_2_ID=second_admin_user_id_here            # leave blank if only 1 admin

# ─── Admin Chat IDs ───────────────────────────────────────────
# Private DM chat IDs — bot sends auto alerts here too
# Usually the same as your user ID for private chats
ADMIN_1_CHAT_ID=your_chat_id_here
ADMIN_2_CHAT_ID=second_admin_chat_id_here       # leave blank if only 1 admin

# ─── Scheduler Intervals ──────────────────────────────────────
SIGNAL_CHECK_INTERVAL=15                        # minutes between market scans
TREND_CHECK_INTERVAL=30                         # minutes between content scans

# ─── Timezone ─────────────────────────────────────────────────
DEFAULT_TIMEZONE=Africa/Lagos

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

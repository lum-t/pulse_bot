# ─── Telegram ────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHANNEL_ID=

# Admin IDs (Telegram user IDs — numbers, not usernames)
ADMIN_1_ID=
ADMIN_2_ID=

# Admin private chat IDs (your DM chat ID with the bot)
ADMIN_1_CHAT_ID=
ADMIN_2_CHAT_ID=

# ─── Scheduler intervals ─────────────────────────────────────
SIGNAL_CHECK_INTERVAL=15   # minutes
TREND_CHECK_INTERVAL=30    # minutes

# ─── AI — Primary (Google Gemini) ───────────────────────────
GEMINI_API_KEY=

# ─── AI — Fallback providers ─────────────────────────────────
# Used automatically when Gemini hits rate limits
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ─── PnL Tracking ────────────────────────────────────────────
PNL_FILE_PATH=pnl_data.json
TAKE_PROFIT_PERCENT=50
STOP_LOSS_PERCENT=30
AUTO_CLOSE_HOURS=8
MID_UPDATE_HOURS=4

# ─── Learning Engine ─────────────────────────────────────────
LEARNING_FILE=trade_lessons.json

# ─── Timezone ────────────────────────────────────────────────
DEFAULT_TIMEZONE=Africa/Lagos
